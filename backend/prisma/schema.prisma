// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum FuelType {
  DIESEL
  PETROL
  ELECTRIC
  CNG
  HYBRID
}

enum DriverStatus {
  ACTIVE
  ON_TRIP
  SUSPENDED
  INACTIVE
}

enum TripStatus {
  SCHEDULED
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceType {
  PREVENTIVE
  REPAIR
  INSPECTION
}

enum MaintenanceStatus {
  OPEN
  COMPLETED
  CANCELLED
}

enum ExpenseCategory {
  FUEL
  TOLL
  MAINTENANCE
  REPAIR
  INSURANCE
  OTHER
}

// ==========================================
// MODELS
// ==========================================

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  role         Role
  isActive     Boolean   @default(true)
  avatarUrl    String?
  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @updatedAt @db.Timestamptz
  deletedAt    DateTime? @db.Timestamptz

  driverProfile   Driver?
  expensesLogged  Expense[]
  maintenanceLogs MaintenanceLog[]

  @@index([role, isActive])
  @@index([email])
  @@map("users")
}

model Driver {
  id            String       @id @default(uuid()) @db.Uuid
  userId        String       @unique @db.Uuid
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber String       @unique
  licenseClass  String
  licenseExpiry DateTime     @db.Date
  status        DriverStatus @default(ACTIVE)
  rating        Decimal?     @db.Decimal(3, 2)
  createdAt     DateTime     @default(now()) @db.Timestamptz
  updatedAt     DateTime     @updatedAt @db.Timestamptz
  deletedAt     DateTime?    @db.Timestamptz

  trips    Trip[]
  fuelLogs FuelLog[]

  @@index([status, licenseExpiry])
  @@index([licenseExpiry])
  @@map("drivers")
}

model Vehicle {
  id                 String        @id @default(uuid()) @db.Uuid
  registrationNumber String        @unique
  make               String
  model              String
  year               Int
  status             VehicleStatus @default(AVAILABLE)
  maxPayloadCapacity Decimal       @db.Decimal(10, 2)
  fuelType           FuelType
  currentOdometer    Int           @default(0)
  createdAt          DateTime      @default(now()) @db.Timestamptz
  updatedAt          DateTime      @updatedAt @db.Timestamptz
  deletedAt          DateTime?     @db.Timestamptz

  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]

  @@index([status, maxPayloadCapacity])
  @@index([currentOdometer])
  @@map("vehicles")
}

model Trip {
  id               String     @id @default(uuid()) @db.Uuid
  tripNumber       String     @unique
  driverId         String     @db.Uuid
  driver           Driver     @relation(fields: [driverId], references: [id])
  vehicleId        String     @db.Uuid
  vehicle          Vehicle    @relation(fields: [vehicleId], references: [id])
  status           TripStatus @default(SCHEDULED)
  startLocation    String
  endLocation      String
  cargoWeight      Decimal    @db.Decimal(10, 2)
  cargoDescription String?
  scheduledStart   DateTime   @db.Timestamptz
  scheduledEnd     DateTime   @db.Timestamptz
  actualStart      DateTime?  @db.Timestamptz
  actualEnd        DateTime?  @db.Timestamptz
  odometerAtStart  Int?
  odometerAtEnd    Int?
  createdAt        DateTime   @default(now()) @db.Timestamptz
  updatedAt        DateTime   @updatedAt @db.Timestamptz
  deletedAt        DateTime?  @db.Timestamptz

  fuelLogs FuelLog[]
  expenses Expense[]

  @@index([driverId])
  @@index([vehicleId])
  @@index([status, scheduledStart(sort: Desc)])
  @@map("trips")
}

model MaintenanceLog {
  id                String            @id @default(uuid()) @db.Uuid
  vehicleId         String            @db.Uuid
  vehicle           Vehicle           @relation(fields: [vehicleId], references: [id])
  loggedById        String            @db.Uuid
  loggedBy          User              @relation(fields: [loggedById], references: [id])
  description       String            @db.Text
  type              MaintenanceType
  status            MaintenanceStatus @default(OPEN)
  cost              Decimal           @default(0.00) @db.Decimal(10, 2)
  odometerAtService Int
  startDate         DateTime          @default(now()) @db.Timestamptz
  endDate           DateTime?         @db.Timestamptz
  createdAt         DateTime          @default(now()) @db.Timestamptz
  updatedAt         DateTime          @updatedAt @db.Timestamptz
  deletedAt         DateTime?         @db.Timestamptz

  expenses Expense[]

  @@index([vehicleId, startDate(sort: Desc)])
  @@index([loggedById])
  @@map("maintenance_logs")
}

model FuelLog {
  id         String    @id @default(uuid()) @db.Uuid
  vehicleId  String    @db.Uuid
  vehicle    Vehicle   @relation(fields: [vehicleId], references: [id])
  driverId   String    @db.Uuid
  driver     Driver    @relation(fields: [driverId], references: [id])
  tripId     String?   @db.Uuid
  trip       Trip?     @relation(fields: [tripId], references: [id])
  quantity   Decimal   @db.Decimal(8, 2)
  cost       Decimal   @db.Decimal(10, 2)
  odometer   Int
  refueledAt DateTime  @default(now()) @db.Timestamptz
  receiptUrl String?
  createdAt  DateTime  @default(now()) @db.Timestamptz
  updatedAt  DateTime  @updatedAt @db.Timestamptz
  deletedAt  DateTime? @db.Timestamptz

  expenses Expense[]

  @@index([vehicleId, refueledAt(sort: Desc)])
  @@index([driverId, refueledAt(sort: Desc)])
  @@index([tripId])
  @@map("fuel_logs")
}

model Expense {
  id               String          @id @default(uuid()) @db.Uuid
  amount           Decimal         @db.Decimal(10, 2)
  category         ExpenseCategory
  description      String
  loggedById       String          @db.Uuid
  loggedBy         User            @relation(fields: [loggedById], references: [id])
  vehicleId        String?         @db.Uuid
  vehicle          Vehicle?        @relation(fields: [vehicleId], references: [id])
  tripId           String?         @db.Uuid
  trip             Trip?           @relation(fields: [tripId], references: [id])
  fuelLogId        String?         @unique @db.Uuid
  fuelLog          FuelLog?        @relation(fields: [fuelLogId], references: [id])
  maintenanceLogId String?         @unique @db.Uuid
  maintenanceLog   MaintenanceLog? @relation(fields: [maintenanceLogId], references: [id])
  expenseDate      DateTime        @default(now()) @db.Timestamptz
  receiptUrl       String?
  createdAt        DateTime        @default(now()) @db.Timestamptz
  updatedAt        DateTime        @updatedAt @db.Timestamptz
  deletedAt        DateTime?       @db.Timestamptz

  @@index([vehicleId, category, expenseDate(sort: Desc)])
  @@index([tripId])
  @@index([expenseDate(sort: Desc), category])
  @@map("expenses")
}
