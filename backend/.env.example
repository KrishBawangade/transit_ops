# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Neon Cloud PostgreSQL)
# DATABASE_URL: Connection pooled link used by application at runtime
DATABASE_URL="postgresql://username:password@ep-pooler-name.region.aws.neon.tech/transitops?sslmode=require&pgbouncer=true"

# DIRECT_URL: Direct link used for migrations (bypasses pooling)
DIRECT_URL="postgresql://username:password@ep-direct-name.region.aws.neon.tech/transitops?sslmode=require"

